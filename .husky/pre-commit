#!/usr/bin/env sh

set -e

staged_cs_files="$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.cs$' || true)"

if [ -z "$staged_cs_files" ]; then
  exit 0
fi

run_quiet() {
  label="$1"
  shift

  output="$("$@" 2>&1)" || {
    status=$?
    echo "✗ $label failed"
    echo "$output"
    exit "$status"
  }
}

run_quiet "dotnet tool restore" dotnet tool restore --verbosity quiet

# If sa1201ier accepts file paths:
echo "$staged_cs_files" | xargs dotnet tool run sa1201ier

# CSharpier accepts paths:
echo "$staged_cs_files" | xargs dotnet tool run csharpier format

# Re-stage formatted files.
echo "$staged_cs_files" | xargs git add